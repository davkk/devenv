#!/usr/bin/env bash

set -euo pipefail

trap 'echo "Interrupted, exiting..."; exit 130' INT

echo "Caching sudo credentials..."
sudo -v

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
lib_file="$script_dir/run.lib"

if [ -z "${DEV_ENV:-}" ]; then
    echo "Error: DEV_ENV env var needs to be present"
    echo "Usage: DEV_ENV=/path/to/repo ./install"
    exit 1
fi

export DEV_ENV="$DEV_ENV"

source "$lib_file"

scripts=()
load_config "$script_dir" scripts

for s in "${scripts[@]}"; do
    echo "Running $s"
    "$script_dir/run" "$s"
done

echo "=== All done ==="
