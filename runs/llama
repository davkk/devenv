#!/usr/bin/env bash

set -euo pipefail

# if command -v llama &>/dev/null || [[ -f "$HOME/git/llama.cpp/build/bin/llama-server" ]]; then
#     exit 0
# fi

GIT_DIR="$HOME/git"

mkdir -p "$GIT_DIR"

if [[ ! -d "$GIT_DIR/llama.cpp/.git" ]]; then
    git clone git@github.com:ggerganov/llama.cpp.git "$GIT_DIR/llama.cpp"
fi

cd "$GIT_DIR/llama.cpp"

rm -rf build
cmake -B build -DBUILD_SHARED_LIBS=OFF -DGGML_VULKAN=ON
cmake --build build --config Release -j 12
sudo cmake --install build
