#!/usr/bin/env bash

set -euo pipefail

case "$OS" in
    fedora)
        sudo dnf update -y &&
        sudo dnf install -y \
            sway grimshot grim slurp jq wl-clipboard \
            git curl wget moreutils \
            desktop-file-utils parallel tmux \
            stow
        ;;
    ubuntu)
        sudo apt update -y &&
        sudo apt install -y \
            sway grimshot grim slurp jq wl-clipboard \
            git curl wget moreutils \
            desktop-file-utils parallel tmux \
            stow
        ;;
esac
