#!/usr/bin/env bash

detect_os() {
    if [[ -f /etc/os-release ]]; then
        . /etc/os-release
        case "$ID" in
            fedora) echo "fedora" ;;
            ubuntu|debian) echo "ubuntu" ;;
            *) echo "unknown" ;;
        esac
    else
        echo "unknown"
    fi
}

load_config() {
    local script_dir="$1"
    local config_file="$script_dir/devenv.conf"
    local -n arr="$2"
    
    if [[ -f "$config_file" ]]; then
        while IFS= read -r s; do
            [[ -z "$s" || "$s" =~ ^# ]] && continue
            s="${s#"${s%%[![:space:]]*}"}"
            [[ -z "$s" ]] && continue
            [[ -x "$script_dir/runs/$s" ]] || continue
            arr+=("$s")
        done < "$config_file"
    fi
}

source_bashrc() {
    [[ -f "$HOME/.bashrc" ]] && { set +eu; . "$HOME/.bashrc"; set -eu; }
}
